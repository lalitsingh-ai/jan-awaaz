# SERVER-SIDE key for the /api/gemini proxy. NOT prefixed with VITE_, so it is
# never bundled into the browser. Set this locally for `vercel dev`, and in the
# Vercel dashboard (Project Settings -> Environment Variables) for production.
# Get a free key at https://aistudio.google.com/apikey
# Leave blank to run in Smart demo mode (deterministic, no AI calls).
GEMINI_API_KEY=
